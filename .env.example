APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=:memory:
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/api/auth/callback/google"

APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_KEY_ID=
APPLE_TEAM_ID=
# Project-relative path (e.g. storage/app/private/AuthKey_XXXXXXXXXX.p8) OR raw PEM contents.
APPLE_PRIVATE_KEY=
APPLE_REDIRECT_URI="${APP_URL}/api/auth/callback/apple"

# Verifone Online Payments (subscription billing)
# Master switch — keep false until the credentials below are filled in.
VERIFONE_ENABLED=false
VERIFONE_ENV=sandbox            # sandbox | production
VERIFONE_REGION=emea            # emea | us | nz  (ISK/Iceland → emea)
# Credentials & identifiers issued by Verifone (Verifone Central → Administration).
VERIFONE_USER_ID=               # Basic-auth user-uid (API keys screen)
VERIFONE_API_KEY=               # Basic-auth API key (API keys screen)
VERIFONE_ENTITY_ID=             # merchant entity / organisation UID
VERIFONE_PAYMENT_CONTRACT_ID=   # payment provider contract UUID
VERIFONE_TOKEN_SCOPE_ID=        # reuse-token scope UUID
VERIFONE_CURRENCY=ISK
# Optional. JWKS URL for webhook signature verification — leave blank to use the
# correct public per-environment default.
VERIFONE_WEBHOOK_JWKS_URL=
# Optional OAuth fallback — only needed if a specific call requires a Bearer JWT
# instead of Basic auth. Leave blank otherwise.
VERIFONE_CLIENT_ID=
VERIFONE_CLIENT_SECRET=
VERIFONE_OAUTH_SCOPE=
